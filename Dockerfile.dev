FROM golang:1.26-alpine AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -o /stevy ./cmd/stevy

FROM gcr.io/distroless/static-debian12

COPY --from=build /stevy /stevy
COPY --from=build /src/public/ /public/

ENTRYPOINT ["/stevy"]

CMD ["serve"]