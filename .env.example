# ──────────────────── Database ────────────────────
# Postgres: postgres://user:pass@host:port/db
# SQLite:   sqlite://./dev.db  (local file)
DATABASE_URL=sqlite://./dev.db

# Run migrations on startup (convenient for dev)
MIGRATE=true

# ──────────────────── Server ────────────────────
PORT=8080

# ──────────────────── Google OAuth ────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match OAUTH_REDIRECT_URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL — used to build the OAuth callback (/auth/google/callback).
HOSTNAME=http://localhost:8080

# ──────────────────── Access control ────────────────────
# Restrict which Google accounts can sign in. If both unset, any Google user can sign in.
# ALLOWED_DOMAINS=stevy.sh

# ──────────────────── Sessions ────────────────────
# 32+ random bytes. Generate: openssl rand -base64 32
SESSION_SECRET=

# ──────────────────── Scheduler ────────────────────
# How often the scheduler runs (promote + expire sweep). Go duration syntax.
# SCHEDULER_INTERVAL=1s

# How long a claimed job lock lasts before the scheduler treats the worker as dead.
# Workers must call HeartbeatJob before this expires to keep the lock alive.
# JOB_LOCK_DURATION=30s
