# ──────────────────── Database ────────────────────
# Postgres: postgres://user:pass@host:port/db
# SQLite:   sqlite://./dev.db  (local file)
DATABASE_URL=sqlite://./dev.db

# Run River + app migrations on startup (convenient for dev)
MIGRATE=true

# ──────────────────── Server ────────────────────
PORT=3000

# ──────────────────── Google OAuth ────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match OAUTH_REDIRECT_URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:3000/auth/google/callback

# ──────────────────── Access control ────────────────────
# Restrict which Google accounts can sign in. If both unset, any Google user can sign in.
# ALLOWED_DOMAINS=stevy.sh

# ──────────────────── Sessions ────────────────────
# 32+ random bytes. Generate: openssl rand -base64 32
SESSION_SECRET=
